rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Allow public read for events
    match /events/{event} {
      allow read: if true;
      allow write: if false; // Only admin via console/CLI
    }
    
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
